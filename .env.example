# ── Data Source & Auth ─────────────────────────────────────────
# Server-side data source strategy
# Options: MEMORY (Default), MOCK (Load from JSON), SUPABASE (Persistent)
DATA_SOURCE=MOCK

# Auth strategy for Client Components — must match DATA_SOURCE
NEXT_PUBLIC_AUTH_STRATEGY=MOCK

# Optional: inactivity timeout in ms (default: 1800000 = 30 min)
NEXT_PUBLIC_SESSION_TIMEOUT_MS=1800000

# Public base URL (used in auth callbacks, e.g. http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Canonical IANA timezone used to decide the current calendar day for the
# billing-cycle date filters (22 → 21). Keeps the server (UTC) and the client in
# agreement so the cycle rolls over on the user's local day, not the server's.
# Default: America/Guayaquil (UTC-5).
NEXT_PUBLIC_APP_TIMEZONE=America/Guayaquil

# ── Supabase (Required if DATA_SOURCE=SUPABASE) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for the push-notification webhook route (bypasses RLS to look up
# a notification's owner and their push_subscriptions). Get it from
# Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Push Notifications (Web Push / VAPID) ──────────────────────
# Generate a keypair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# Shared secret checked by /api/webhooks/notifications. Set the same value
# as a header in the Supabase Database Webhook that calls this route
# (see supabase/migrations/20260718130000_notifications_webhook.sql).
NOTIFICATIONS_WEBHOOK_SECRET=generate-a-long-random-string

# ── Financial Module: Feature Flags ───────────────────────────
# Enables Supabase Realtime websocket subscriptions (default: false)
NEXT_PUBLIC_FF_FINANCIAL_REALTIME=false

# Enables fallback HTTP polling when realtime is off (default: true)
NEXT_PUBLIC_FF_FINANCIAL_POLLING=true

# Enables AI-driven transaction categorization (default: false, experimental)
NEXT_PUBLIC_FF_FINANCIAL_AI=false

# Enables IndexedDB offline caching (default: true)
NEXT_PUBLIC_FF_FINANCIAL_OFFLINE=true

# Enables recurring transaction detection (default: false, experimental)
NEXT_PUBLIC_FF_FINANCIAL_RECURRING=false

# Polling interval (ms) for realtime fallback (default: 60000)
NEXT_PUBLIC_FINANCIAL_POLLING_INTERVAL_MS=60000

# N8N webhook for automated financial scanning (optional)
N8N_SCANNER_WEBHOOK_URL=https://your-n8n-instance.com/webhook/finance-scanner/async
