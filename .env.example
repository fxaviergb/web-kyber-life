# ── Data Source & Auth ─────────────────────────────────────────
# Server-side data source strategy
# Options: MEMORY (Default), MOCK (Load from JSON), SUPABASE (Persistent)
DATA_SOURCE=MOCK

# Auth strategy for Client Components — must match DATA_SOURCE
NEXT_PUBLIC_AUTH_STRATEGY=MOCK

# Optional: inactivity timeout in ms (default: 1800000 = 30 min)
NEXT_PUBLIC_SESSION_TIMEOUT_MS=1800000

# Public base URL (used in auth callbacks, e.g. http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Supabase (Required if DATA_SOURCE=SUPABASE) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-key (Optional, for admin tasks)

# ── Financial Module: Feature Flags ───────────────────────────
# Enables Supabase Realtime websocket subscriptions (default: false)
NEXT_PUBLIC_FF_FINANCIAL_REALTIME=false

# Enables fallback HTTP polling when realtime is off (default: true)
NEXT_PUBLIC_FF_FINANCIAL_POLLING=true

# Enables AI-driven transaction categorization (default: false, experimental)
NEXT_PUBLIC_FF_FINANCIAL_AI=false

# Enables IndexedDB offline caching (default: true)
NEXT_PUBLIC_FF_FINANCIAL_OFFLINE=true

# Enables recurring transaction detection (default: false, experimental)
NEXT_PUBLIC_FF_FINANCIAL_RECURRING=false

# Polling interval (ms) for realtime fallback (default: 60000)
NEXT_PUBLIC_FINANCIAL_POLLING_INTERVAL_MS=60000
